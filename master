kubectl wait --for=condition=Ready \
  certificate/static-site-root-ca \
  -n cert-manager \
  --timeout=300s

kubectl get clusterissuer
kubectl get certificate -n cert-manager
kubectl get secret static-site-root-ca-secret -n cert-manager





#
# create namespace and RBAC for site deployment
cat > 02-rbac-static-site.yaml <<'EOF'
apiVersion: v1
kind: Namespace
metadata:
  name: static-site
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: site-deployer
  namespace: static-site
---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: static-site-deployer
  namespace: static-site
rules:
  - apiGroups: [""]
    resources:
      - configmaps
      - services
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]

  - apiGroups: [""]
    resources:
      - pods
      - pods/log
      - events
      - secrets
    verbs: ["get", "list", "watch"]

  - apiGroups: ["apps"]
    resources:
      - deployments
      - replicasets
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]

  - apiGroups: ["networking.k8s.io"]
    resources:
      - ingresses
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]

  - apiGroups: ["cert-manager.io"]
    resources:
      - certificates
    verbs: ["get", "list", "watch", "create", "update", "patch", "delete"]

  - apiGroups: ["cert-manager.io"]
    resources:
      - certificaterequests
    verbs: ["get", "list", "watch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: static-site-deployer-binding
  namespace: static-site
subjects:
  - kind: ServiceAccount
    name: site-deployer
    namespace: static-site
roleRef:
  kind: Role
  name: static-site-deployer
  apiGroup: rbac.authorization.k8s.io
EOF

kubectl apply -f 02-rbac-static-site.yaml

kubectl auth can-i create deployments \
  --as=system:serviceaccount:static-site:site-deployer \
  -n static-site

kubectl auth can-i create ingresses \
  --as=system:serviceaccount:static-site:site-deployer \
  -n static-site

kubectl auth can-i create clusterissuers \
  --as=system:serviceaccount:static-site:site-deployer

# optional: create a kubeconfig for the deployer
TOKEN=$(kubectl create token site-deployer -n static-site --duration=24h)
KUBE_API=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}')
KUBE_CA=$(kubectl config view --raw --minify -o jsonpath='{.clusters[0].cluster.certificate-authority-data}')

cat > site-deployer.kubeconfig <<EOF
apiVersion: v1
kind: Config
clusters:
- name: kubeadm-cluster
  cluster:
    server: ${KUBE_API}
    certificate-authority-data: ${KUBE_CA}
contexts:
- name: site-deployer@kubeadm-cluster
  context:
    cluster: kubeadm-cluster
    namespace: static-site
    user: site-deployer
current-context: site-deployer@kubeadm-cluster
users:
- name: site-deployer
  user:
    token: ${TOKEN}
EOF

kubectl --kubeconfig=site-deployer.kubeconfig auth can-i create deployments
kubectl --kubeconfig=site-deployer.kubeconfig auth can-i create ingresses
kubectl --kubeconfig=site-deployer.kubeconfig auth can-i create clusterissuers




