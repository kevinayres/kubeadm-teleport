# ingress-nginx with fixed NodePorts for AWS NLB forward
helm upgrade --install ingress-nginx ingress-nginx \
  --repo https://kubernetes.github.io/ingress-nginx \
  --namespace ingress-nginx \
  --create-namespace \
  --set controller.service.type=NodePort \
  --set controller.service.nodePorts.http=30080 \
  --set controller.service.nodePorts.https=30443

kubectl get svc -n ingress-nginx
#NAME                                 TYPE        CLUSTER-IP       EXTERNAL-IP   PORT(S)                      AGE
#ingress-nginx-controller             NodePort    10.109.168.193   <none>        80:30080/TCP,443:30443/TCP   37s
#ingress-nginx-controller-admission   ClusterIP   10.99.225.242    <none>        443/TCP                      37s

